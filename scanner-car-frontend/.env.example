# CARWEB Frontend — Variables de Entorno

# URL del API Backend (NestJS)
# Desarrollo local
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Producción (Render) — descomentar y configurar
# NEXT_PUBLIC_API_URL=https://tu-backend.onrender.com/api

# ── SEO ─────────────────────────────────────────────────────────────────────
# Dominio público canónico. IMPRESCINDIBLE en producción: si no se define,
# todos los canonical/hreflang/sitemap/JSON-LD usan el fallback https://carweb.com.co
NEXT_PUBLIC_SITE_URL=https://carweb.com.co

# ── Analítica / Monetización (opcionales) ───────────────────────────────────
# Google Analytics 4 (GA4) — formato G-XXXXXXXXXX
# NEXT_PUBLIC_GA_ID=
# Google AdSense — ID de editor, formato ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_CLIENT=
# Verificación de Google Search Console (meta tag) — solo el token
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
