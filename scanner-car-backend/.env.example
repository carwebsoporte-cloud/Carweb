# CARWEB Backend - Variables de Entorno

# Base de datos MySQL (coincide con prisma/schema.prisma → provider = "mysql")
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASEDEDATOS
DATABASE_URL="mysql://root:password@localhost:3306/scanner_car_db"

# Puerto del servidor
PORT=3001

# Entorno (en "production" se desactiva Swagger y se exigen los secretos)
NODE_ENV="development"

# CORS - URL del frontend
CORS_ORIGIN="http://localhost:3000"

# URL pública del backend (para construir las URLs de /uploads)
PUBLIC_BACKEND_URL="http://localhost:3001"

# Panel administrativo (login único). OBLIGATORIOS: el backend falla si faltan.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambia-esta-clave-por-una-fuerte"
# Genera uno con: openssl rand -base64 48   (mínimo 32 caracteres)
ADMIN_JWT_SECRET="cambia-esto-por-una-cadena-aleatoria-de-minimo-32-caracteres"
